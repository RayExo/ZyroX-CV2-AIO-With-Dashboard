# API URL for the dashboard backend
NEXT_PUBLIC_API_URL=https://your-api-host/api/v1

# API key shared with the bot's DASHBOARD_API_KEY.
# SECURITY: this is a SERVER-ONLY variable (no NEXT_PUBLIC_) — it is never
# shipped to the browser. Generate a strong unique value (min 32 chars), e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DASHBOARD_API_KEY=

# NextAuth Configuration
# REQUIRED: generate with `openssl rand -base64 32` or
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
NEXTAUTH_URL=https://your-vercel-url.vercel.app/
NEXTAUTH_SECRET=

# Discord OAuth configuration
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Admin User IDs (comma separated) — SERVER-ONLY, not exposed to the browser.
ADMIN_IDS=

# Customizable Brand / Bot name shown across the dashboard
NEXT_PUBLIC_BRAND_NAME="ZyroX"
NEXT_PUBLIC_BRAND_NAME_WORD="ZX"
